FROM python:3.11-slim

WORKDIR /app

# Install only what the frontend needs
RUN pip install --no-cache-dir streamlit==1.40.2 requests==2.32.3

# Copy app source
COPY . .

EXPOSE 8501

CMD ["streamlit", "run", "streamlit_app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
